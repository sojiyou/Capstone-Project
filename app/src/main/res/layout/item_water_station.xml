<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="7dp">

        <!-- Station Name and Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvStationName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Station Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/somewhat_blue" />

            <TextView
                android:id="@+id/tvStationStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Open"
                android:textSize="11sp"
                android:textColor="#4CAF50"
                android:padding="4dp"
                android:background="@drawable/status_badge_background" />
        </LinearLayout>

        <!-- Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="14sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvStationAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Address"
                android:textSize="12sp"
                android:textColor="#666666"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Distance -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚗"
                android:textSize="14sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvStationDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculating distance..."
                android:textSize="12sp"
                android:textColor="#666666" />
        </LinearLayout>

        <!-- Pricing Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:padding="8dp"
            android:background="@drawable/pricing_info_background">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pure: "
                android:textSize="11sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/tvPurePrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00  "
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/somewhat_blue" />

            <!-- Vertical Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/light_yellow"
                android:layout_gravity="center_vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spring: "
                android:textSize="11sp"
                android:textColor="#666666"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/tvSpringPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00  "
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/somewhat_blue" />

            <!-- Vertical Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/light_yellow"
                android:layout_gravity="center_vertical" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mineral: "
                android:textSize="11sp"
                android:textColor="#666666"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/tvMineralPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/somewhat_blue" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="100px"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnViewOnMap"
                android:layout_width="200px"
                android:layout_height="90px"
                android:text="View on Map"
                android:textSize="10sp"
                android:background="@drawable/button_background2"
                android:textColor="@color/somewhat_blue"
                android:padding="5dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnOrderNow"
                android:layout_width="200px"
                android:layout_height="90px"
                android:text="Order Now"
                android:textSize="10sp"
                android:background="@drawable/button_background"
                android:textColor="@color/white"
                android:padding="5dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>